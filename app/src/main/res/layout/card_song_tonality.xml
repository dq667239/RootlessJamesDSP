<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/song_tonality_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tonality_title"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/song_tonality_descriptor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/tonality_waiting"
            android:textAppearance="?attr/textAppearanceBody1"
            tools:text="Bass-heavy: +4.2 dB bass, -2.8 dB air vs approximate M-Noise." />

        <me.timschneeberger.rootlessjamesdsp.view.MNoiseDeviationSurface
            android:id="@+id/mnoise_deviation_surface"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:layout_marginTop="12dp"
            android:paddingStart="28dp"
            android:paddingTop="8dp"
            android:paddingEnd="8dp"
            android:paddingBottom="22dp" />

        <TextView
            android:id="@+id/song_tonality_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/tonality_trace_legend"
            android:textAppearance="?attr/textAppearanceBody2" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
